# Browser-safe Supabase configuration. These are the only Supabase values exposed to Vite/frontend code.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side only. Configure this as a Cloudflare Pages encrypted secret.
# Never prefix this with VITE_ and never import it in src/ frontend code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional local demo users script values.
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=ChangeMe123!
DEMO_CUSTOMER_PASSWORD=ChangeMe123!
